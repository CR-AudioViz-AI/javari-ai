{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "github": {
    "enabled": true,
    "autoAlias": false,
    "silent": false,
    "autoJobCancelation": true
  },
  "crons": [
    {
      "path": "/api/javari/queue",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/javari/autonomy/cycle",
      "schedule": "*/3 * * * *"
    }
  ]
}
